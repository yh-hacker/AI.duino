{
  "name": "aiduino",
  "displayName": "AI.duino",
  "description": "AI-powered assistance for Arduino for API-, local- and process providers.",
  "version": "2.8.2",
  "license": "Apache-2.0",
  "publisher": "yh-hacker",
  "icon": "icons/aiduino.png",
  "repository": {
      "type": "git",
      "url": "https://github.com/yh-hacker/AI.duino"
  },
  "homepage": "https://github.com/yh-hacker/AI.duino",
  "license": "Apache-2.0",
  "bugs": {
      "url": "https://github.com/yh-hacker/AI.duino/issues"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other",
    "Debuggers",
    "Education"
  ],
  "keywords": [
      "arduino",
      "arduinoIDE",
      "ai",
      "claude",
      "chatgpt",
      "gemini",
      "mistral",
      "perplexity",
      "cohere",
      "groq",
      "nvidia",
      "deepseek",
      "debug",
      "error",
      "help",
      "assistant",
      "ollama",
      "embedded",
      "platformio",
      "iot",
      "microcontroller",
      "local llm"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "aiduino-activitybar": [
        {
          "id": "aiduino.quickMenuView",
          "name": "AI.duino Quick Menu",
          "when": "true"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiduino-activitybar",
          "title": "AI.duino",
          "icon": "./icons/aiduino-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "aiduino.quickMenu",
        "title": "🤖 AI.duino",
        "category": "AI.duino",
        "icon": "$(robot)"
      },
      {
        "command": "aiduino.switchModel",
        "title": "Switch AI Model",
        "category": "AI.duino",
        "icon": "$(sync)"
      },
      {
        "command": "aiduino.setApiKey",
        "title": "Enter API Key",
        "category": "AI.duino",
        "icon": "$(key)"
      },
      {
        "command": "aiduino.improveCode",
        "title": "Improve Code",
        "category": "AI.duino",
        "icon": "$(symbol-method)"
      },
      {
        "command": "aiduino.explainCode",
        "title": "Explain Code",
        "category": "AI.duino",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "aiduino.addComments",
        "title": "Add Comments",
        "category": "AI.duino",
        "icon": "$(edit)"
      },
      {
        "command": "aiduino.explainError",
        "title": "Explain Error",
        "category": "AI.duino",
        "icon": "$(error)"
      },
      {
        "command": "aiduino.explainCopiedError",
        "title": "Explain Copied Error",
        "category": "AI.duino"
      },
      {
        "command": "aiduino.askAI",
        "title": "Ask AI",
        "category": "AI.duino",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "aiduino.openChatPanel",
        "title": "Open AI Chat Panel",
        "category": "AI.duino",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "aiduino.debugHelp",
        "title": "Debug Help",
        "category": "AI.duino",
        "icon": "$(bug)"
      },
      {       
        "command": "aiduino.runCustomAgent",
        "title": "Run Custom Agent",
        "category": "AI.duino",
        "icon": "$(robot)"
      },
      {
        "command": "aiduino.analyzeCode",
        "title": "Analyze Code (Offline)",
        "category": "AI.duino"
      },
      {
        "command": "aiduino.manageCustomAgents",
        "title": "Manage Custom Agents",
        "category": "AI.duino",
        "icon": "$(robot)"
      },
      {
        "command": "aiduino.switchLanguage",
        "title": "Switch Language",
        "category": "AI.duino",
        "icon": "$(globe)"
      },
      {
        "command": "aiduino.editPrompts",
        "title": "Edit Prompts",
        "category": "AI.duino",
        "icon": "$(edit)"
      },
      {
        "command": "aiduino.toggleInlineCompletion",
        "title": "Toggle Inline Completion",
        "category": "AI.duino",
        "icon": "$(wand)"
      },
      {
        "command": "aiduino.openSettings",
        "title": "Open Settings",
        "category": "AI.duino"
      }
    ],
    "keybindings": [
      {
        "command": "aiduino.quickMenu",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus && (resourceExtname == .ino || resourceExtname == .cpp || resourceExtname == .h || resourceExtname == .c)"
      },
      {
        "command": "aiduino.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus && (resourceExtname == .ino || resourceExtname == .cpp || resourceExtname == .h || resourceExtname == .c)"
      },
      {
        "command": "aiduino.askAI",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus"
      },
      {
        "command": "aiduino.openChatPanel", 
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorTextFocus"
      },
      {
        "command": "aiduino.explainCopiedError",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus && (resourceExtname == .ino || resourceExtname == .cpp || resourceExtname == .h || resourceExtname == .c)"
      },
      {
        "command": "aiduino.openSettings",
        "key": "ctrl+shift+,",
        "mac": "cmd+shift+,",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "aiduino.quickMenu",
          "group": "1_modification",
          "when": "resourceExtname == .ino"
        },
        {
          "command": "aiduino.quickMenu",
          "group": "1_modification",
          "when": "resourceExtname == .cpp"
        },
        {
          "command": "aiduino.quickMenu",
          "group": "1_modification",
          "when": "resourceExtname == .h"
        },
        {
          "command": "aiduino.quickMenu",
          "group": "1_modification",
          "when": "resourceExtname == .c"
        }
      ]
    },
    "configuration": {
      "title": "AI.duino",
      "properties": {
        "aiduino.defaultModel": {
          "type": "string",
          "default": "claude",
          "description": "Default AI model on startup"
        },
        "aiduino.language": {
          "type": "string",
          "default": "auto",
          "description": "Language for plugin UI and AI responses. Use 'auto' for VS Code language detection, or specify a language code (e.g., 'en', 'de', 'fr', 'ro'). Available languages are automatically detected from the locales folder."
        },
        "aiduino.cardStyle": {
          "type": "string",
          "default": "arduino-green",
          "enum": ["arduino-green", "white-border"],
          "enumDescriptions": [
            "Arduino green background with white text",
            "White background with green border (better readability)"
          ],
          "description": "Visual style for chat and agent selection cards"
        },
        "aiduino.projectNotesEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable project notes feature (NOTES.ino)"
        },
        "aiduino.autoOpenInChat": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open AI results in chat instead of output panel"
        },
        "aiduino.showCostWarning": {
          "type": "boolean",
          "default": true,
          "description": "Show warning before high-cost API calls"
        },
        "aiduino.costWarningThreshold": {
          "type": "number",
          "default": 0.10,
          "minimum": 0.01,
          "maximum": 10.0,
          "description": "Cost threshold in USD for showing warning"
        },
        "aiduino.maxTokensPerRequest": {
          "type": "number",
          "default": 4000,
          "minimum": 1000,
          "maximum": 8000,
          "description": "Maximum tokens per AI request"
        },
        "aiduino.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 1,
          "description": "AI creativity level (0 = deterministic, 1 = creative)"
        },
        "aiduino.codeTemperature": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 1,
          "description": "Temperature for code generation and improvements (lower=more deterministic)"
        },
        "aiduino.maxCustomAgents": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum number of custom agents (1-100)"
        },
        "aiduino.tokenEstimationMultiplier": {
          "type": "number",
          "default": 0.75,
          "minimum": 0.1,
          "maximum": 2,
          "description": "Multiplier for word-to-token estimation"
        },
        "aiduino.tokenEstimationCodeBlock": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Additional tokens per code block"
        },
        "aiduino.tokenEstimationSpecialChars": {
          "type": "number",
          "default": 0.2,
          "minimum": 0.1,
          "maximum": 1,
          "description": "Multiplier for special characters"
        },
        "aiduino.customInstructionsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable custom instructions for code improvements"
        },
        "aiduino.chatHistoryLength": {
          "type": "number",
          "default": 20,
          "minimum": 4,
          "maximum": 50,
          "description": "Number of messages to include in chat history (pairs of user/AI messages)"
        },
        "aiduino.promptHistoryLength": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "maximum": 10,
          "description": "Number of prompts to save and display in prompt history"
        },
        "aiduino.inlineCompletionEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable inline code completion"
        },
        "aiduino.inlineCompletionProvider": {
          "type": "string",
          "default": "groq",
          "description": "Provider for inline completion"
        },
        "aiduino.apiTimeout": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "maximum": 120000,
          "description": "API request timeout in milliseconds"
        },
        "aiduino.apiMaxRetries": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "maximum": 10,
          "description": "Maximum number of retry attempts on API errors"
        },
        "aiduino.maxChats": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum number of stored chat conversations"
        },
        "aiduino.maxMessagesPerChat": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum messages per chat (older messages are deleted)"
        },
        "aiduino.inlineCompletionDelay": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 2000,
          "description": "Delay between inline completions in milliseconds"
        },
        "aiduino.inlineCompletionContextLines": {
          "type": "number",
          "default": 20,
          "minimum": 5,
          "maximum": 50,
          "description": "Number of lines before cursor to use as context"
        },
        "aiduino.inlineCompletionMinCommentLength": {
          "type": "number",
          "default": 10,
          "minimum": 2,
          "maximum": 20,
          "description": "Minimum comment length to trigger completion"
        },
        "aiduino.inlineCompletionMaxLinesComment": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "maximum": 50,
          "description": "Maximum lines for comment-to-code completions"
        },
        "aiduino.inlineCompletionMaxLinesSimple": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum lines for simple completions"
        },
        "aiduino.customApiEndpoint": {
          "type": "string",
          "default": "",
          "description": "Custom OpenAI-compatible API endpoint URL (e.g., https://api.example.com)"
        },
        "aiduino.customApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for custom OpenAI-compatible endpoint"
        },
        "aiduino.customModelId": {
          "type": "string",
          "default": "",
          "description": "Model ID for custom OpenAI-compatible endpoint"
        }
      } 
    }   
  },
  "author": {
    "name": "Monster Maker"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yh-hacker/AI.duino"
  },
  "bugs": {
    "url": "https://github.com/yh-hacker/AI.duino/issues"
  },
  "homepage": "https://github.com/yh-hacker/AI.duino#readme"
}
